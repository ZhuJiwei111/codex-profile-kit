{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON3}} {{HOME}}/.codex/hooks/direct_download_guard.py",
            "timeout": 10,
            "statusMessage": "Checking direct-download policy"
          },
          {
            "type": "command",
            "command": "{{PYTHON3}} {{HOME}}/.codex/hooks/hookify_codex_runner.py --event PreToolUse",
            "timeout": 10,
            "statusMessage": "Checking global command rules"
          }
        ]
      },
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON3}} {{HOME}}/.codex/hooks/hookify_codex_runner.py --event PreToolUse",
            "timeout": 10,
            "statusMessage": "Checking global file-edit rules"
          }
        ]
      }
    ]
  }
}
